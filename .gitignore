# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.kiro
.windsurf
.trae
.roo
.qoder
.opencode

# IDEs and editors
.vscode/
.idea/
.history/

# cache and build artifacts
.cache/
dist/
/.turbo/

# local envs & secrets (explicit local files; keep .env.example committed)
# Note: existing `env*` already ignores env files; keep this for clarity
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS files
.thumbs.db
.DS_Store

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.cursor
.gemini
.github
.codex
.continue
.github